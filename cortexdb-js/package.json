{
  "name": "@harshit-sandilya/cortexdb-js",
  "version": "0.2.5",
  "description": "CortexDB JavaScript/TypeScript SDK — A RAG-powered memory database client.",
  "repository": {
    "type": "git",
    "url": "git://github.com/harshit-sandilya/CortexDB.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx main.ts",
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run --config vitest.unit.config.ts && vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts"
  },
  "keywords": [
    "cortexdb",
    "rag",
    "vector-database",
    "knowledge-graph",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}